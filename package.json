{
  "name": "enterprise-discord-music-bot",
  "version": "1.0.0",
  "description": "Production-ready Discord music bot powered by Discord.js, Shoukaku, Lavalink, PostgreSQL, Redis, and Clean Architecture.",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=11"
  },
  "scripts": {
    "build": "tsup src/main.ts src/scripts/registerCommands.ts --format esm --target node22 --sourcemap --clean --out-dir dist",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "commands:register": "tsx src/scripts/registerCommands.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "clean": "rimraf dist coverage"
  },
  "dependencies": {
    "@discordjs/voice": "0.19.2",
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/rate-limit": "11.1.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "6.0.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "discord.js": "14.26.4",
    "dotenv": "17.4.2",
    "fastify": "5.10.0",
    "ioredis": "5.11.1",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "prom-client": "15.1.3",
    "prisma": "7.8.0",
    "shoukaku": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.0",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "pino-pretty": "13.1.3",
    "prettier": "3.9.4",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}
